{
  "name": "open-telemetry/opentelemetry-metrics-runtime",
  "description": "OpenTelemetry PHP runtime metrics (memory, GC, OPcache, CPU)",
  "keywords": ["opentelemetry", "otel", "open-telemetry", "metrics", "runtime", "php"],
  "type": "library",
  "homepage": "https://opentelemetry.io/docs/languages/php/",
  "readme": "./README.md",
  "license": "Apache-2.0",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "^8.1",
    "open-telemetry/api": "^1.1",
    "open-telemetry/sem-conv": "^1.38",
    "symfony/polyfill-php82": "^1.0",
    "composer-runtime-api": "^2.0",
    "tbachert/spi": "^1.0.1"
  },
  "require-dev": {
    "open-telemetry/sdk": "^1.1",
    "friendsofphp/php-cs-fixer": "^3",
    "phan/phan": "^5.0|^6.0",
    "phpstan/phpstan": "^1.1",
    "phpstan/phpstan-phpunit": "^1.0",
    "psalm/plugin-phpunit": "^0.20",
    "phpunit/phpunit": "^10.0",
    "vimeo/psalm": "^6"
  },
  "autoload": {
    "psr-4": {
      "OpenTelemetry\\Contrib\\Metrics\\Runtime\\": "src/"
    },
    "files": [
      "_register.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "OpenTelemetry\\Contrib\\Metrics\\Runtime\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": false,
      "tbachert/spi": true
    }
  },
  "extra": {
    "spi-config": {
      "autoload-files": true
    }
  }
}
