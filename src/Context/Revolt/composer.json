{
    "name": "open-telemetry/opentelemetry-revolt-adapter",
    "description": "OpenTelemetry Revolt adapter",
    "keywords": ["opentelemetry", "otel", "context", "revolt", "event-loop"],
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.1",
        "open-telemetry/context": "^1.0",
        "revolt/event-loop": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "open-telemetry/api": "^1.1",
        "open-telemetry/sdk": "^1.14",
        "phpunit/phpunit": "^9",
        "vimeo/psalm": "^6.16"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false,
            "tbachert/spi": true
        },
        "preferred-install": {
            "revolt/event-loop": "source"
        }
    },
    "suggest": {
        "revolt/event-loop-adapter-react": "To support react/event-loop"
    },
    "autoload": {
        "psr-4": {
            "OpenTelemetry\\Contrib\\Context\\Revolt\\": "src/"
        },
        "files": [
            "bootstrap.php",
            "_register.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "OpenTelemetry\\Contrib\\Context\\Revolt\\": "tests/",
            "Revolt\\EventLoop\\": "vendor/revolt/event-loop/test/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "spi-config": {
            "autoload-files": [
                "_register.php"
            ]
        }
    }
}
